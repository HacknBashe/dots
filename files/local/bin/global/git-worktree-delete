#!/usr/bin/env bash

git_common_dir="$(realpath "$(git rev-parse --git-common-dir 2>/dev/null)")" || {
  echo "ERROR: Not in a git repo"
  exit 1
}

# New structure: repos live directly in a directory (e.g., ~/src/Social)
# Worktrees are created as siblings with naming: {repo}_{branch}
# git-common-dir points to the main repo's .git (even from worktrees)
main_repo_dir="$(dirname "$git_common_dir")"
repo_name="$(basename "$main_repo_dir")"

# Check if a branch name was provided as an argument
if [ $# -eq 1 ]; then
  target_branch="$1"

  # Get all worktrees with their branches
  worktree_info=$(git worktree list --porcelain)

  # Find the worktree path for the specified branch
  selected_path=""
  selected_branch=""

  while IFS= read -r line; do
    if [[ $line == worktree* ]]; then
      current_path="${line#worktree }"
    elif [[ $line == branch* ]]; then
      current_branch="${line#branch }"
      current_branch="${current_branch#refs/heads/}" # Remove refs/heads/ prefix if present

      if [[ "$current_branch" == "$target_branch" ]]; then
        selected_path="$current_path"
        selected_branch="$current_branch"
        break
      fi
    fi
  done <<<"$worktree_info"

  if [ -z "$selected_path" ]; then
    echo "No worktree found for branch '$target_branch'"
    echo "Available worktrees:"
    git worktree list
    echo ""
    echo "Attempting to delete branch directly..."
    git branch -D "$target_branch"
    exit $?
  fi
else
  # No argument provided, use fzf selection (original behavior)
  worktree_info=$(git worktree list --porcelain)

  # Extract and format worktree paths and branches for selection
  # Filter out the main worktree (it contains the .git directory)
  formatted_worktrees=$(echo "$worktree_info" |
    awk 'BEGIN {path=""; branch=""} 
    /^worktree / {path=substr($0, 10)} 
    /^branch / {branch=substr($0, 8)} 
    branch != "" && path != "" {print path " [" branch "]"; path=""; branch=""}' |
    grep -v "^${main_repo_dir} ")

  if [ -z "$formatted_worktrees" ]; then
    echo "No deletable worktrees found (main worktree is protected)."
    exit 0
  fi

  # Let user select a worktree to delete
  selected=$(echo "$formatted_worktrees" | fzf --height 10 --reverse) || exit 1

  # Extract path and branch from selection
  selected_path=$(echo "$selected" | awk '{print $1}')
  selected_branch=$(echo "$selected" | sed -E 's/.*\[(.*)\].*/\1/' | sed 's/refs\/heads\///')
fi

# Protect the main worktree — it contains the .git directory that all worktrees depend on
selected_path_resolved="$(realpath "$selected_path" 2>/dev/null || echo "$selected_path")"
main_repo_resolved="$(realpath "$main_repo_dir")"

if [[ "$selected_path_resolved" == "$main_repo_resolved" ]]; then
  echo "ERROR: Refusing to delete the main worktree at $selected_path"
  echo "This is the primary repository that contains the .git directory."
  echo "Deleting it would destroy all worktrees."
  exit 1
fi

echo "Removing worktree at $selected_path"
echo "and deleting branch $selected_branch"

# Kill associated tmux session early in the process
formatted_branch=$(echo "$selected_branch" | tr '/' '-')
session_name="${repo_name}_${formatted_branch}"

if tmux has-session -t "$session_name" 2>/dev/null; then
  echo "Killing tmux session: $session_name"
  tmux kill-session -t "$session_name"
fi

# Make sure we're not in the worktree we're trying to delete
if [[ "$PWD" == "$selected_path"* ]]; then
  cd "$main_repo_dir"
fi

# Remove the worktree and delete the branch
git worktree remove --force "$selected_path" 2>/dev/null

# If git worktree remove failed but directory still exists, force cleanup
if [ -d "$selected_path" ]; then
  rm -rf "$selected_path"
  git worktree prune
fi

# Delete the branch (regardless of how the directory was removed)
if [ -d "$selected_path" ]; then
  echo "ERROR: Directory still exists at $selected_path"
  exit 1
else
  git branch -D "$selected_branch" 2>/dev/null
fi

git worktree list
