#!/usr/bin/env bash

# Exit on any error
set -e

# Check if we're in a git repo
git_common_dir="$(realpath "$(git rev-parse --git-common-dir 2>/dev/null)")" || {
  echo "Error: Not in a git repository"
  exit 1
}

# New structure: repos live directly in a directory (e.g., ~/src/Social)
# Worktrees are created as siblings with naming: {repo}_{branch}
# git-common-dir points to the main repo's .git (even from worktrees)
main_repo_dir="$(dirname "$git_common_dir")"
repo_name="$(basename "$main_repo_dir")"
current_dir="$(realpath "$PWD")"
current_branch=$(git branch --show-current)

# Check if we're in the main repository (not a separate worktree)
if [[ "$current_dir" == "$main_repo_dir" ]]; then
  echo "Error: You're in the main repository. This script is for deleting separate worktrees."
  echo "Current branch: $current_branch"
  if [[ "$current_branch" == "master" ]] || [[ "$current_branch" == "main" ]]; then
    echo "You're on the main branch in the main repository."
  else
    echo "Switch to master/main branch and use 'git branch -D $current_branch' to delete this branch."
  fi
  exit 1
fi

# Verify we're actually in a worktree (not the main repo)
if ! git worktree list | grep -q "$current_dir"; then
  echo "Error: Current directory doesn't appear to be a worktree"
  exit 1
fi

# Get current tmux session if we're in one
current_session=""
if [[ -n "$TMUX" ]]; then
  current_session=$(tmux display-message -p '#S')
fi

echo "Current worktree: $current_dir"
echo "Current branch: $current_branch"
if [[ -n "$current_session" ]]; then
  echo "Current tmux session: $current_session"
fi
echo ""

# Confirm deletion
read -p "Delete current worktree, branch, and tmux session? (y/N): " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  exit 0
fi

# Main repo session name is just the repo name (no _master suffix)
main_session_name="$repo_name"

# Check if we're in tmux and handle session switching
if [[ -n "$current_session" ]] && command -v tmux >/dev/null 2>&1; then
  echo "Switching to main repo tmux session: $main_session_name"
  
  # Create main repo session if it doesn't exist
  if ! tmux has-session -t "$main_session_name" 2>/dev/null; then
    tmux new-session -ds "$main_session_name" -c "$main_repo_dir"
  fi
  
  # Switch to main repo session first
  tmux switch-client -t "$main_session_name"
  
  # Now kill the old session (but only if it's different from main session)
  if [[ "$current_session" != "$main_session_name" ]]; then
    echo "Killing old tmux session: $current_session"
    tmux kill-session -t "$current_session" 2>/dev/null || true
  fi
fi

# Change to main repo directory before deleting current worktree
cd "$main_repo_dir"

# Remove the worktree and delete the branch
echo "Removing worktree: $current_dir"
git worktree remove --force "$current_dir"

echo "Deleting branch: $current_branch"
git branch -D "$current_branch"

echo "Worktree and branch deleted successfully."

# Handle case where we weren't in tmux initially
if [[ -z "$current_session" ]] && command -v tmux >/dev/null 2>&1 && pgrep tmux >/dev/null 2>&1; then
  echo "Creating/switching to main repo tmux session: $main_session_name"
  
  # Create session if it doesn't exist
  if ! tmux has-session -t "$main_session_name" 2>/dev/null; then
    tmux new-session -ds "$main_session_name" -c "$main_repo_dir"
  fi
  
  # Attach to the session
  exec tmux attach -t "$main_session_name"
elif [[ -z "$current_session" ]]; then
  echo "Tmux not running. You are now in: $main_repo_dir"
fi