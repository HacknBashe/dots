#!/usr/bin/env bash
# Full session status refresh: queries tmux panes, computes icons/labels,
# reads Blazar build state from cache, then writes per-session data to a
# cache file and calls tmux_session_status_render to update the status bar.
#
# Called from:
#   - tmux_session_status_poll (status-interval periodic polling)
#   - client-session-changed hook (background, after instant render from cache)
#
# Cache format (one line per session, pipe-delimited, ordered by session):
#   session_name|all_icons_with_tmux_formatting|label|session_id

source "$(dirname "${BASH_SOURCE[0]}")/tmux_helpers"

CACHE_DIR="/tmp/tmux_status"
CACHE_FILE="${CACHE_DIR}/sessions"
BLAZAR_CACHE_DIR="${CACHE_DIR}/blazar"

mkdir -p "$CACHE_DIR"

# Read theme colors in a single tmux call (render script reads current session separately)
IFS='|' read -r thm_yellow thm_blue thm_orange thm_white thm_green thm_grey thm_dark <<< \
    "$(tmux display-message -p '#{@thm_yellow}|#{@thm_blue}|#{@thm_orange}|#{@thm_white}|#{@thm_green}|#{@thm_grey}|#{@thm_dark}')"

# Extract first three descriptive words from a session name (split on - or _).
# Strips issue prefix (e.g. "nh-3609") wherever it appears so the label shows
# the descriptive part of the branch name instead.
session_label() {
    local name="$1"
    # Strip issue prefix like "nh-13466" (short alpha + digits) with surrounding separators
    local stripped
    stripped=$(printf '%s' "$name" | sed -E 's/(^|[_-])[a-zA-Z]{1,4}-[0-9]+([_-]|$)/\1/; s/^[-_]+//; s/[-_]+/-/g; s/[-_]$//')
    [[ -z "$stripped" ]] && stripped="$name"
    local words
    IFS='-' read -ra words <<< "${stripped//_/-}"
    if [[ ${#words[@]} -ge 3 ]]; then
        printf '%s %s %s' "${words[0]}" "${words[1]}" "${words[2]}"
    elif [[ ${#words[@]} -ge 2 ]]; then
        printf '%s %s' "${words[0]}" "${words[1]}"
    else
        printf '%s' "${words[0]}"
    fi
}

# Collect session paths for Blazar status lookup
declare -A session_path
while IFS='|' read -r sname spath; do
    session_path["$sname"]="$spath"
done < <(tmux list-sessions -F "#{session_name}|#{session_path}")

# Collect agent/shell pane data per session in a single pass
declare -A agent_status agent_cmd shell_cmd

while IFS='|' read -r session ptype pstatus pcmd; do
    case "$ptype" in
        agent) agent_status["$session"]="$pstatus"; agent_cmd["$session"]="$pcmd" ;;
        shell) shell_cmd["$session"]="$pcmd" ;;
    esac
done < <(tmux list-panes -a -F "#{session_name}|#{@pane_type}|#{@pane_status}|#{pane_current_command}")

# Build cache lines
cache_lines=""

while IFS='|' read -r session session_id; do
    label=$(session_label "$session")
    icons=""

    # Agent pane icon
    if [[ -n "${agent_cmd[$session]+x}" ]]; then
        if is_shell_prompt "${agent_cmd[$session]}"; then
            icons+="#[fg=${thm_white}]${ICON_SHELL}"
        else
            icon=$(get_agent_status_icon "${agent_status[$session]}")
            case "${agent_status[$session]}" in
                waiting) icons+="#[fg=${thm_orange}]${icon}" ;;
                working) icons+="#[fg=${thm_blue}]${icon}" ;;
                seen)    icons+="#[fg=${thm_white}]${icon}" ;;
                *)       icons+="#[fg=${thm_blue}]${icon}" ;;
            esac
        fi
    fi

    # Shell pane icon (colored by status: blue=running, white=idle)
    if [[ -n "${shell_cmd[$session]+x}" ]]; then
        if is_shell_prompt "${shell_cmd[$session]}"; then
            icons+="#[fg=${thm_white}]${ICON_SHELL}"
        else
            icons+="#[fg=${thm_blue}]${ICON_RUNNING}"
        fi
    fi

    # Blazar build status icon (read from cache, background-refreshed by tmux_blazar_status)
    blazar_icon=""
    blazar_state=$(tmux_blazar_status "${session_path[$session]}" "$session" 2>/dev/null)
    case "$blazar_state" in
        success) blazar_icon="#[fg=${thm_green}]${ICON_BLAZAR_SUCCESS}" ;;
        pending) blazar_icon="#[fg=${thm_yellow}]${ICON_BLAZAR_PENDING}" ;;
        failure|error) blazar_icon="#[fg=${thm_orange}]${ICON_BLAZAR_FAILURE}" ;;
    esac

    all_icons="${icons}${blazar_icon}"

    # Write to cache: session_name|icons|label|session_id (one line per session, ordered)
    cache_lines+="${session}|${all_icons}|${label}|${session_id}"$'\n'
done < <(tmux list-sessions -F "#{session_name}|#{session_id}" | sort -t'$' -k2 -n)

# Write cache file atomically
printf '%s' "$cache_lines" > "${CACHE_FILE}.tmp" && mv "${CACHE_FILE}.tmp" "$CACHE_FILE"

# Render the status bar from the cache we just wrote
exec tmux_session_status_render
