#!/usr/bin/env bash
# Generates tmux status bar showing all sessions in a window-tab style
# Called periodically via tmux_session_status_poll (status-interval polling)
#
# Each session shows: [index icons label]
# - Label is the first two words of the session name (hyphen/underscore separated)
# - Current session is highlighted (yellow text, grey bg), others are white on dark bg
# - Agent icon colored by status: orange=waiting, blue=working, dim=idle/seen
# - Shell icon shown when a command is running, dim when idle
#
# Writes per-session icon/label data to a cache file so that
# tmux_session_status_fast can re-render highlighting instantly on session switch
# without re-polling pane data or Blazar status.

CACHE_FILE="/tmp/tmux_session_icons"

source "$(dirname "${BASH_SOURCE[0]}")/tmux_helpers"

# Read current session and theme colors in a single tmux call
IFS='|' read -r current_session thm_yellow thm_blue thm_orange thm_white thm_green thm_grey thm_dark <<< \
    "$(tmux display-message -p '#S|#{@thm_yellow}|#{@thm_blue}|#{@thm_orange}|#{@thm_white}|#{@thm_green}|#{@thm_grey}|#{@thm_dark}')"

# Extract first two words from a session name (split on - or _)
session_label() {
    local name="$1"
    local words
    IFS='-' read -ra words <<< "${name//_/-}"
    if [[ ${#words[@]} -ge 2 ]]; then
        printf '%s %s' "${words[0]}" "${words[1]}"
    else
        printf '%s' "${words[0]}"
    fi
}

# Collect session paths for Blazar status lookup
declare -A session_path
while IFS='|' read -r sname spath; do
    session_path["$sname"]="$spath"
done < <(tmux list-sessions -F "#{session_name}|#{session_path}")

# Collect agent/shell pane data per session in a single pass
declare -A agent_status agent_cmd shell_cmd

while IFS='|' read -r session ptype pstatus pcmd; do
    case "$ptype" in
        agent) agent_status["$session"]="$pstatus"; agent_cmd["$session"]="$pcmd" ;;
        shell) shell_cmd["$session"]="$pcmd" ;;
    esac
done < <(tmux list-panes -a -F "#{session_name}|#{@pane_type}|#{@pane_status}|#{pane_current_command}")

# Build status output and cache file
output=""
cache_lines=""
idx=0

while IFS='|' read -r session session_id; do
    label=$(session_label "$session")
    icons=""

    # Agent pane icon
    if [[ -n "${agent_cmd[$session]+x}" ]]; then
        if is_shell_prompt "${agent_cmd[$session]}"; then
            icons+="#[fg=${thm_white}]${ICON_SHELL}"
        else
            icon=$(get_agent_status_icon "${agent_status[$session]}")
            case "${agent_status[$session]}" in
                waiting) icons+="#[fg=${thm_orange}]${icon}" ;;
                working) icons+="#[fg=${thm_blue}]${icon}" ;;
                seen)    icons+="#[fg=${thm_white}]${icon}" ;;
                *)       icons+="#[fg=${thm_blue}]${icon}" ;;
            esac
        fi
    fi

    # Shell pane icon (colored by status: blue=running, white=idle)
    if [[ -n "${shell_cmd[$session]+x}" ]]; then
        if is_shell_prompt "${shell_cmd[$session]}"; then
            icons+="#[fg=${thm_white}]${ICON_SHELL}"
        else
            icons+="#[fg=${thm_blue}]${ICON_RUNNING}"
        fi
    fi

    # Blazar build status icon
    blazar_icon=""
    blazar_state=$(tmux_blazar_status "${session_path[$session]}" "$session" 2>/dev/null)
    case "$blazar_state" in
        success) blazar_icon="#[fg=${thm_green}]${ICON_BLAZAR_SUCCESS}" ;;
        pending) blazar_icon="#[fg=${thm_yellow}]${ICON_BLAZAR_PENDING}" ;;
        failure|error) blazar_icon="#[fg=${thm_orange}]${ICON_BLAZAR_FAILURE}" ;;
    esac

    all_icons="${icons}${blazar_icon}"

    # Write to cache: session_name|icons|label (one line per session, ordered)
    cache_lines+="${session}|${all_icons}|${label}"$'\n'

    # Format: " index icons name "
    if [[ "$session" == "$current_session" ]]; then
        output+="#[fg=${thm_yellow},bg=${thm_grey}] ${idx} ${all_icons} #[fg=${thm_yellow}]${label} "
    else
        output+="#[fg=${thm_white},bg=${thm_dark}] ${idx} ${all_icons} #[fg=${thm_white}]${label} "
    fi
    ((idx++))
done < <(tmux list-sessions -F "#{session_name}|#{session_id}" | sort -t'$' -k2 -n)

# Write cache file atomically
printf '%s' "$cache_lines" > "${CACHE_FILE}.tmp" && mv "${CACHE_FILE}.tmp" "$CACHE_FILE"

# Set tmux option for instant display and refresh
tmux set -g @session_bar "$output"
tmux refresh-client -S 2>/dev/null
