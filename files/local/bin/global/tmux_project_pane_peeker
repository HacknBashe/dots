#!/usr/bin/env bash

# FZF-based project pane picker with live preview
# Usage: tmux_project_pane_peeker <pane_type>
# Example: tmux_project_pane_peeker agent
#          tmux_project_pane_peeker nvim

source "$(dirname "${BASH_SOURCE[0]}")/tmux_helpers"

# Check if argument is provided
if [[ $# -eq 0 ]]; then
    echo "Usage: $0 <pane_type>"
    echo "Example: $0 agent"
    echo "         $0 nvim"
    echo "         $0 yazi"
    exit 1
fi

pane_type="$1"

# Get all project panes of the specified type and format them nicely
# Sorted by icon priority: waiting > idle > working > seen > shell-prompt
get_project_panes() {
    local pattern="${pane_type}\$"

    # Pre-compute session index (matching status bar order)
    declare -A session_idx
    local idx=0
    while IFS= read -r sess; do
        session_idx["$sess"]=$idx
        ((idx++))
    done < <(tmux list-sessions -F "#{session_name}|#{session_id}" | sort -t'$' -k2 -n | cut -d'|' -f1)

    # Pre-compute worktree labels and shell status per session from shell panes.
    # This lets non-shell pane types (agents, etc.) inherit the session's worktree
    # and display the shell icon alongside their own icon.
    declare -A session_wt
    declare -A session_shell_icon
    while IFS='|' read -r sess sid _ shell_cmd; do
        local swt
        swt=$(tmux capture-pane -t "$sid" -p -S -200 < /dev/null 2>/dev/null | sed -n 's/.*bend worktree: \([^ ]*\).*/\1/p' | tail -1)
        [[ -n "$swt" ]] && session_wt["$sess"]="$swt"
        if is_shell_prompt "$shell_cmd"; then
            session_shell_icon["$sess"]="$ICON_SHELL"
        else
            session_shell_icon["$sess"]="$ICON_RUNNING"
        fi
    done < <(tmux list-panes -a -F "#{session_name}|#{pane_id}|#{@pane_type}|#{pane_current_command}" | grep '|shell|')

    # First pass: collect entries and track max worktree label width
    local entries=()
    local max_wt_len=0

    while IFS='|' read -r session_name pane_id current_command pane_status pane_type_val; do
        local symbol=""
        local sort_key="5"  # Default: lowest priority
        if ! is_shell_prompt "$current_command"; then
            case "$pane_type_val" in
                agent)
                    symbol=$(get_agent_status_icon "$pane_status")
                    sort_key=$(get_agent_sort_priority "$pane_status")
                    ;;
                *) symbol="$ICON_RUNNING"; sort_key="3" ;;
            esac
        else
            symbol="$ICON_SHELL"; sort_key="5"
        fi

        # Worktree: check pane's own scrollback first, fall back to session's shell pane
        local wt=""
        wt=$(tmux capture-pane -t "$pane_id" -p -S -200 < /dev/null 2>/dev/null | sed -n 's/.*bend worktree: \([^ ]*\).*/\1/p' | tail -1)
        [[ -z "$wt" ]] && wt="${session_wt[$session_name]:-}"
        if [[ -n "$wt" ]]; then
            local len=${#wt}
            (( len > max_wt_len )) && max_wt_len=$len
        fi

        entries+=("${sort_key}|${pane_id}|${symbol}|${wt}|${current_command}|${session_name}|${pane_type_val}")
    done < <(tmux list-panes -a -F "#{session_name}|#{pane_id}|#{pane_current_command}|#{@pane_status}|#{@pane_type}" | grep "|${pattern}")

    # Second pass: format with aligned worktree column
    local wt_col_width=0
    (( max_wt_len > 0 )) && wt_col_width=$(( max_wt_len + 3 ))  # [] + trailing space

    for entry in "${entries[@]}"; do
        IFS='|' read -r sort_key pane_id symbol wt current_command session_name pane_type_val <<< "$entry"

        local wt_display=""
        if (( wt_col_width > 0 )); then
            if [[ -n "$wt" ]]; then
                printf -v wt_display "%-${wt_col_width}s" "[$wt]"
            else
                printf -v wt_display "%-${wt_col_width}s" ""
            fi
        fi

        local sidx="${session_idx[$session_name]:-?}"

        if [[ "$pane_type_val" == "agent" ]]; then
            local shell_icon="${session_shell_icon[$session_name]:-}"
            printf "%s|%s %s %s%s %s%s\n" "$sort_key" "$pane_id" "$sidx" "$symbol" "$shell_icon" "$wt_display" "$session_name"
        else
            printf "%s|%s %s %s %s%-10s %s\n" "$sort_key" "$pane_id" "$sidx" "$symbol" "$wt_display" "$current_command" "$session_name"
        fi
    done | sort -t'|' -k1,1n | cut -d'|' -f2-
}

# Write entries to tmpfile so digit keybindings can look up by session index
tmpfile=$(mktemp)
trap "rm -f '$tmpfile'" EXIT
get_project_panes > "$tmpfile"

# Build fzf options based on pane type
fzf_opts=(
    --ansi
    --layout=reverse
    --border
    --with-nth=2..
    --select-1
    --exit-0
)

# Bind digit keys to jump directly to the matching session index
for d in $(seq 0 9); do
    fzf_opts+=(--bind "$d:become(awk '\$2==\"$d\"' '$tmpfile')")
done

if [[ "$pane_type" == "agent" ]]; then
    # Combined view: tall preview on top (agent + shell), short fzf list at bottom
    fzf_opts+=(
        --preview="
            pane_id=\$(echo {} | awk '{print \$1}')
            session_name=\$(echo {} | awk '{print \$NF}')
            preview_lines=\$(tput lines)
            agent_lines=\$(( preview_lines * 45 / 100 ))
            shell_lines=\$(( preview_lines - agent_lines - 3 ))

            # Agent output
            tmux capture-pane -t \"\$pane_id\" -e -p | grep -v '^[[:space:]]*\$' | tail -\$agent_lines

            # Separator
            printf '%0.s─' \$(seq 1 \$(tput cols))
            echo

            # Shell output - find shell pane in same session
            shell_pane=\$(tmux list-panes -s -t \"\$session_name\" -F '#{pane_id} #{@pane_type}' 2>/dev/null | grep ' shell\$' | head -1 | awk '{print \$1}')
            if [[ -n \"\$shell_pane\" ]]; then
                tmux capture-pane -t \"\$shell_pane\" -e -p | grep -v '^[[:space:]]*\$' | tail -\$shell_lines
            fi
        "
        --preview-window=up:80%
        --header="Select the agent pane to switch to"
    )
else
    # Standard view for non-agent pane types
    fzf_opts+=(
        --preview="
            pane_id=\$(echo {} | awk '{print \$1}')
            session_name=\$(echo {} | awk '{print \$NF}')
            preview_height=\$(($(tput lines) - 7))
            echo \"=== \$session_name (${pane_type} pane) ===\"
            echo
            tmux capture-pane -t \"\$pane_id\" -e -p | grep -v '^[[:space:]]*\$' | tail -\$preview_height
        "
        --preview-window=right:60%
        --header="Select the ${pane_type} pane to switch to"
    )
fi

selected=$(fzf < "$tmpfile" "${fzf_opts[@]}")

if [[ -n "$selected" ]]; then
    pane_id=$(echo "$selected" | awk '{print $1}')

    # Clear notification status if pane is idle (not working/waiting)
    # This marks it as "seen" so we know we've checked it
    pane_status=$(tmux display-message -p -t "$pane_id" '#{@pane_status}')
    if [[ "$pane_status" != "working" && "$pane_status" != "waiting" ]]; then
        tmux set-option -p -t "$pane_id" @pane_status "seen"
    fi

    # Get the window containing this pane
    target_window=$(tmux list-panes -a -F "#{pane_id} #{session_name}:#{window_id}" | grep "^$pane_id " | cut -d' ' -f2)

    # Switch to the session and window, then select the pane
    tmux switch-client -t "$target_window"
    tmux select-pane -t "$pane_id"
fi
