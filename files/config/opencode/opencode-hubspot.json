{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "lsp": {},
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--browserUrl",
        "http://127.0.0.1:9222"
      ]
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "nix *": "ask",
      "git *": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git diff*": "allow",
      "git branch": "allow",
      "git branch -l*": "allow",
      "git branch --list*": "allow",
      "git branch --show-current*": "allow",
      "git remote": "allow",
      "git remote get-url*": "allow",
      "git remote -v*": "allow",
      "git ls-files*": "allow",
      "git cat-file*": "allow",
      "git rev-parse*": "allow",
      "git describe*": "allow",
      "git config --get*": "allow",
      "git config --list*": "allow"
    }
  },
  "default_agent": "plan",
  "agent": {
    "ship": {
      "description": "Ship code with full git and GitHub CLI permissions",
      "mode": "primary",
      "color": "warning",
      "permission": {
        "bash": {
          "git add *": "allow",
          "git commit *": "allow",
          "git push *": "allow",
          "git checkout *": "allow",
          "git switch *": "allow",
          "git branch *": "allow",
          "git merge *": "allow",
          "git rebase *": "allow",
          "git stash *": "allow",
          "gh *": "allow"
        }
      }
    }
  }
}
